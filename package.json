{
  "name": "arise-sites",
  "version": "1.0.0",
  "description": "Static website builder for Arise Dothan — Handlebars templates + JSON config, built to static HTML and deployed to GitHub Pages.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {

    "build:arise": "node build.js arise-dothan",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "clean-css": "^5.3.3",
    "handlebars": "^4.7.8",
    "html-minifier-terser": "^7.2.0",
    "marked": "^18.0.5",
    "sharp": "^0.34.5",
    "terser": "^5.31.0",
    "yaml": "^2.9.0"
  }
}
